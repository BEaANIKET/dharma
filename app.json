{
  "expo": {
    "name": "mydharma",
    "slug": "mydharma",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mydharmalogo.png",
    "scheme": "mydharma",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aniketchaturvedi.dharma"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#09080E",
        "foregroundImage": "./assets/images/mydharmalogo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.aniketchaturvedi.dharma"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/mydharmalogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/mydharmalogo.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#09080E",
          "dark": {
            "backgroundColor": "#09080E"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
